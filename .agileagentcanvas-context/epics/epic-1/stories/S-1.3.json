      "asA": "Engineering Manager",
      "iWant": "to see an interactive visual graph of task dependencies",
      "soThat": "I can identify critical path items and unblock my team"
    },
    "acceptanceCriteria": [
      {
        "id": "AC-1.3.1",
        "given": "tasks have dependency relationships",
        "when": "I open the dependency view",
        "then": "a directed graph shows tasks as nodes and dependencies as edges",
        "and": []
      },
      {
        "id": "AC-1.3.2",
        "given": "a task is blocked",
        "when": "I click on it in the graph",
        "then": "the blocking chain is highlighted in red",
        "and": []
      },
      {
        "id": "AC-1.3.3",
        "given": "the graph is displayed",
        "when": "I hover over a node",
        "then": "a tooltip shows task details, assignee, and estimated completion",
        "and": []
      }
    ],
