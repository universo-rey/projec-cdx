        "complexity": "high"
      },
      {
        "id": "KF-2",
        "name": "Focus Mode",
        "description": "Focus Mode with smart notification batching and do-not-disturb scheduling",
        "priority": "must-have",
        "complexity": "medium"
      },
      {
        "id": "KF-3",
        "name": "Dependency Graph Visualization",
        "description": "Real-time dependency graph visualization showing blockers and critical path",
        "priority": "should-have",
        "complexity": "high"
      },
      {
        "id": "KF-4",
        "name": "Automated Sprint Planning",
        "description": "Automated sprint planning with capacity-aware task assignment",
        "priority": "should-have",
        "complexity": "high"
      },
      {
        "id": "KF-5",
        "name": "Natural Language Task Input",
        "description": "Natural language task creation and updates via CLI and chat integrations",
        "priority": "could-have",
        "complexity": "medium"
      },
      {
        "id": "KF-6",
        "name": "Predictive Delivery Forecasting",
        "description": "Predictive delivery forecasting using historical velocity data",
        "priority": "could-have",
        "complexity": "high"
      }
