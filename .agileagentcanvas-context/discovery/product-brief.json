    "marketContext": {
      "overview": "Dominated by Jira, Asana, and Linear. Gap exists for AI-native, developer-first task management.",
      "targetMarket": "Teams migrating from heavy PM tools to lightweight, opinionated alternatives. $15B TAM by 2026.",
      "competitors": [
        {
          "name": "Linear",
          "description": "Developer-focused project management tool",
          "strengths": [
            "Fast UI",
            "Developer-friendly"
          ],
          "weaknesses": [
            "Limited AI capabilities",
            "No focus modes"
          ]
        },
        {
          "name": "Jira",
          "description": "Enterprise project management platform",
          "strengths": [
            "Enterprise features",
            "Extensive integrations"
          ],
          "weaknesses": [
            "Slow performance",
            "Complex configuration",
            "Reporting-focused"
          ]
        },
        {
          "name": "Asana",
          "description": "Work management platform for teams",
          "strengths": [
            "Visual workflows",
            "Portfolio management"
          ],
          "weaknesses": [
            "Not developer-centric",
            "Expensive for small teams"
          ]
        }
      ]
    },
