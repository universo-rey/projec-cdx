      {
        "id": "EPIC-3",
        "title": "Focus Mode & Productivity",
        "goal": "Create a distraction-free work environment that helps engineers achieve flow state by intelligently managing notifications, task visibility, and focus time tracking.",
        "description": "Focus Mode provides a deep-work environment with Pomodoro-style timers, intelligent notification batching (P0 breakthrough only), and productivity analytics. Integrates with the AI engine for smart task queue ordering and with Slack for DND status sync.",
        "valueDelivered": "Engineers report 40% fewer context switches. Teams see 25% sprint velocity improvement. Focus time data helps managers protect deep work hours.",
        "functionalRequirements": ["FR-3"],
        "nonFunctionalRequirements": ["NFR-1"],
        "implementationNotes": [
          "Pomodoro timer with configurable work/break intervals (default 25/5 minutes)",
          "Notification batching uses a priority queue — P0 breaks through, P1-P3 are batched",
          "Focus analytics stored in TimescaleDB for efficient time-series queries",
          "Team-wide notification rules configurable by Engineering Managers"
        ],
        "status": "draft",
        "priority": "must-have",
        "storyCount": 3,
        "acceptanceSummary": "Epic is complete when focus mode activates/deactivates reliably, notification batching works with priority override, analytics show accurate time tracking, and the focus UI passes accessibility audit.",
        "epicDependencies": {
          "upstream": [
            { "epicId": "EPIC-1", "reason": "Focus Mode needs task filtering API and notification infrastructure from Core Platform" },
            { "epicId": "EPIC-2", "reason": "Focus Mode uses AI priority scores to determine which tasks to show in focus queue" }
          ],
          "downstream": [
            { "epicId": "EPIC-4", "reason": "Slack integration syncs DND status with Focus Mode" }
          ],
          "relatedEpics": []
        },
        "stories": [
          {
            "id": "S-3.1",
            "title": "Focus Mode Core Engine",
            "userStory": {
              "asA": "Software Engineer",
              "iWant": "to activate a focus mode that filters my view to only the current task",
              "soThat": "I can work without distraction for extended periods",
              "formatted": "As a Software Engineer, I want to activate a focus mode that filters my view to only the current task, so that I can work without distraction for extended periods."
            },
            "acceptanceCriteria": [
              { "id": "AC-3.1.1", "given": "I click 'Start Focus'", "when": "focus mode activates", "then": "the UI shows only my current task, related context, and a focus timer" },
              { "id": "AC-3.1.2", "given": "I am in focus mode", "when": "a notification arrives", "then": "it is queued and batched for delivery when focus ends (unless P0 urgent)" },
              { "id": "AC-3.1.3", "given": "focus mode is active for 25 minutes", "when": "the timer triggers a break", "then": "a gentle notification suggests a 5-minute break (Pomodoro-style)" }
            ],
            "status": "draft",
            "storyPoints": 8,
            "priority": "must-have",
            "assignee": "Alex Rivera",
            "requirementRefs": ["FR-3"],
            "testCases": ["TC-3.1.1", "TC-3.1.2", "TC-3.1.3"],
            "implementationDetails": [
              "Focus state machine: idle -> focusing -> break -> focusing (loop) -> ended",
              "Notification interceptor middleware that checks focus state before delivery",
              "Focus session events published for analytics and Slack DND sync"
            ],
