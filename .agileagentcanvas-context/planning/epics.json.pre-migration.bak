        "id": "EPIC-2",
        "title": "AI Prioritization Engine",
        "goal": "Build an intelligent prioritization system that learns from team behavior and automatically ranks tasks by urgency, impact, and dependencies.",
        "description": "The AI Prioritization Engine uses machine learning to automatically score and rank tasks. It learns from team patterns, accounts for deadlines and dependencies, and provides sprint planning suggestions. Includes a rule-based fallback for teams without sufficient training data.",
        "valueDelivered": "Teams spend 60% less time on manual prioritization. AI suggestions improve sprint planning accuracy by 30%. Blocked tasks are surfaced proactively.",
        "functionalRequirements": ["FR-2", "FR-5"],
        "implementationNotes": [
          "ML model trained on historical task completion data — needs minimum 50 completed tasks",
          "Rule-based fallback uses deadline proximity, dependency blocking count, and manual priority",
          "OpenAI API used for natural language priority inference — requires caching and rate limit handling",
          "Priority scores recalculated on task mutation events from the Core Platform"
        ],
        "status": "in-progress",
        "priority": "must-have",
        "storyCount": 3,
        "acceptanceSummary": "Epic is complete when AI scoring achieves > 80% accuracy vs. human-assigned priorities on golden dataset, fallback mode works without OpenAI, and sprint planning suggestions are accepted by EMs > 70% of the time.",
