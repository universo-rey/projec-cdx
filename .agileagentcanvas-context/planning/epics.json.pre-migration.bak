        "risks": {
          "risks": [
            {
              "id": "RISK-01",
              "risk": "WebSocket scaling at 10K connections",
              "category": "performance",
              "probability": "medium",
              "impact": "high",
              "riskScore": "high",
              "impactDescription": "If WebSocket cannot scale, real-time board updates will lag or fail, degrading the core user experience",
              "mitigation": "Redis pub/sub for horizontal scaling",
              "mitigationStrategies": [
                { "strategy": "Implement Redis pub/sub adapter for WebSocket messages", "owner": "Platform Team", "status": "in-progress" },
                { "strategy": "Add connection pooling and graceful degradation to polling", "owner": "Backend Team", "status": "planned" }
              ],
              "contingencyPlan": "Fall back to HTTP polling with 2-second intervals if WebSocket connections exceed capacity",
              "triggers": ["WebSocket connection errors exceed 1% of total connections", "Message delivery latency exceeds 2 seconds"],
              "owner": "Marcus Johnson",
              "status": "mitigating",
              "residualRisk": "low",
              "relatedRequirements": ["NFR-2"],
              "notes": "Load testing scheduled for Sprint 3"
            },
            {
              "id": "RISK-02",
              "risk": "Drag-and-drop conflicts with concurrent users",
              "category": "technical",
              "probability": "medium",
              "impact": "medium",
              "riskScore": "medium",
              "impactDescription": "Two users moving the same card simultaneously could cause data inconsistency or confusing UI state",
              "mitigation": "Optimistic locking with version vectors",
              "mitigationStrategies": [
                { "strategy": "Implement optimistic concurrency control with version vectors on task updates", "owner": "Backend Team", "status": "planned" }
              ],
              "contingencyPlan": "Show conflict resolution dialog when concurrent edits are detected",
              "triggers": ["More than 3 concurrent edit conflicts reported per day"],
