      {
        "id": "EPIC-4",
        "title": "Integration Platform",
        "goal": "Connect TaskFlow Pro with the tools teams already use — GitHub for code, Slack for communication — creating a seamless workflow without tab-switching.",
        "description": "The Integration Platform connects TaskFlow Pro to GitHub and Slack, enabling bidirectional sync. PRs auto-link to tasks, Slack slash commands manage tasks, Focus Mode syncs with Slack DND, and a CLI tool lets developers manage tasks from the terminal.",
        "valueDelivered": "Engineers manage tasks without leaving their IDE or chat. PRs auto-link to tasks. Slack commands create and update tasks. Focus mode syncs with Slack DND.",
        "functionalRequirements": ["FR-6"],
        "additionalRequirements": ["ADD-1"],
        "implementationNotes": [
          "GitHub integration uses GitHub Apps (not OAuth) for fine-grained repository permissions",
          "Slack integration uses Bolt SDK with Socket Mode for development and HTTP for production",
          "CLI tool published to npm as @taskflow/cli with auto-update via npm version checks",
          "All integrations use the same internal task API — no direct database access"
        ],
        "status": "draft",
        "priority": "should-have",
        "storyCount": 3,
        "acceptanceSummary": "Epic is complete when GitHub webhook processes PR events correctly, Slack slash commands work in all channel types, CLI is installable via npm with < 5 second startup, and integration tests cover happy path and error cases.",
        "epicDependencies": {
