              "risk": "GitHub API rate limits during large monorepo pushes",
              "category": "integration",
              "probability": "medium",
              "impact": "medium",
              "riskScore": "medium",
              "impactDescription": "Large monorepos with many PRs per day could exhaust GitHub API rate limits, delaying task-PR linking",
              "mitigation": "Webhook-based approach (no polling), request queuing with exponential backoff",
              "mitigationStrategies": [
                { "strategy": "Use webhook events instead of polling — eliminates most API calls", "owner": "Backend Team", "status": "implemented" },
