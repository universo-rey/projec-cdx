    "epics": [
      {
        "id": "EPIC-1",
        "title": "Core Task Platform",
        "goal": "Build the foundational task management system with CRUD operations, real-time collaboration, and dependency tracking — the backbone that all other epics build upon.",
        "description": "The Core Task Platform is the foundational layer of TaskFlow Pro. It provides the task data model, REST API, real-time WebSocket sync, and interactive dependency graph visualization. All other epics depend on this platform being stable and performant.",
        "valueDelivered": "Users can create, manage, and track tasks with real-time updates and visual dependency graphs. This is the minimum viable product that delivers immediate value.",
        "functionalRequirements": ["FR-1", "FR-4"],
        "nonFunctionalRequirements": ["NFR-1", "NFR-2"],
        "implementationNotes": [
          "Use Prisma ORM with PostgreSQL for the data layer — schema must support future partitioning by workspace_id",
          "WebSocket connections managed via Redis pub/sub for horizontal scaling across multiple server instances",
          "Dependency graph uses d3-dag for layout computation and React SVG rendering for interactivity",
          "All task mutations must publish domain events to enable real-time sync and audit logging"
        ],
        "status": "in-progress",
        "priority": "must-have",
        "storyCount": 3,
        "acceptanceSummary": "Epic is complete when all three stories (CRUD API, Real-time Board, Dependency Graph) pass acceptance criteria, performance benchmarks meet NFR targets, and code review by 2 engineers is done.",
        "epicDependencies": {
          "upstream": [],
          "downstream": [
            { "epicId": "EPIC-2", "reason": "AI prioritization requires task data and dependency graph from Core Platform" },
            { "epicId": "EPIC-3", "reason": "Focus Mode needs task filtering and notification infrastructure from Core Platform" },
            { "epicId": "EPIC-4", "reason": "Integrations need task CRUD API and webhook infrastructure from Core Platform" }
          ],
          "relatedEpics": []
        },
        "stories": [
          {
            "id": "S-1.1",
            "title": "Task CRUD API & Data Model",
            "userStory": {
              "asA": "Software Engineer",
              "iWant": "to create, read, update, and delete tasks via a fast API",
              "soThat": "I can manage my work items programmatically and through the UI",
              "formatted": "As a Software Engineer, I want to create, read, update, and delete tasks via a fast API, so that I can manage my work items programmatically and through the UI."
            },
            "acceptanceCriteria": [
              { "id": "AC-1.1.1", "given": "I am authenticated", "when": "I send a POST to /api/tasks with valid fields", "then": "a new task is created and returned with a unique ID" },
              { "id": "AC-1.1.2", "given": "a task exists", "when": "I send a PATCH with updated fields", "then": "the task is updated and a change event is published" },
              { "id": "AC-1.1.3", "given": "a task exists", "when": "I send a DELETE", "then": "the task is soft-deleted and removed from active views" },
              { "id": "AC-1.1.4", "given": "multiple tasks exist", "when": "I query with filters (assignee, label, status)", "then": "only matching tasks are returned, sorted by priority" }
            ],
            "status": "done",
            "storyPoints": 8,
            "priority": "must-have",
            "estimatedEffort": "2 sprints",
            "assignee": "Alex Rivera",
            "requirementRefs": ["FR-1", "NFR-1"],
            "testCases": ["TC-1.1.1", "TC-1.1.2", "TC-1.1.3", "TC-1.1.4"],
            "implementationDetails": [
              "Prisma schema with Task model supporting workspace_id partitioning",
              "Fastify routes with Zod request/response validation",
              "Domain event publisher using Node EventEmitter bridged to Redis pub/sub",
              "Soft-delete via deletedAt timestamp column with query-level filtering"
            ],
            "dependencies": {
              "blockedBy": [],
              "blocks": [
                { "storyId": "S-1.2", "title": "Real-time Task Board UI" },
                { "storyId": "S-1.3", "title": "Dependency Graph Visualization" },
                { "storyId": "S-2.1", "title": "AI Priority Scoring Engine" },
                { "storyId": "S-3.1", "title": "Focus Mode Core" }
              ],
              "relatedStories": ["S-4.1"],
              "externalDependencies": [
                { "dependency": "PostgreSQL schema migration", "status": "completed", "owner": "Platform Team" }
              ]
            },
            "technicalNotes": "Schema must support future partitioning by workspace_id for multi-tenant scaling.",
            "notes": "This is the foundational story — all other work depends on the API being stable and well-documented."
          },
          {
            "id": "S-1.2",
            "title": "Real-time Task Board UI",
            "userStory": {
              "asA": "Product Manager",
              "iWant": "to see tasks on a kanban board that updates in real-time",
              "soThat": "I always have an accurate view of team progress without refreshing",
              "formatted": "As a Product Manager, I want to see tasks on a kanban board that updates in real-time, so that I always have an accurate view of team progress without refreshing."
            },
            "acceptanceCriteria": [
              { "id": "AC-1.2.1", "given": "I am on the task board", "when": "another team member moves a task", "then": "the card moves on my board within 500ms" },
              { "id": "AC-1.2.2", "given": "I drag a task card", "when": "I drop it in a new column", "then": "the task status updates and all viewers see the change" },
              { "id": "AC-1.2.3", "given": "multiple users are viewing the board", "when": "a new task is created via API or CLI", "then": "the card appears on all boards automatically" }
            ],
            "status": "in-progress",
            "storyPoints": 13,
            "priority": "must-have",
            "estimatedEffort": "3 sprints",
            "assignee": "Jordan Park",
            "requirementRefs": ["FR-1", "NFR-2"],
            "uxReferences": ["wireframe-kanban-board-v2.fig", "design-system-card-component.fig"],
            "testCases": ["TC-1.2.1", "TC-1.2.2", "TC-1.2.3"],
            "blockers": ["WebSocket reconnection logic needs testing under flaky network conditions"],
            "implementationDetails": [
              "React DnD Kit for drag-and-drop with optimistic updates",
              "WebSocket client with exponential backoff reconnection",
              "Virtual scrolling for boards with 500+ cards using react-window"
            ],
            "dependencies": {
              "blockedBy": [
                { "storyId": "S-1.1", "title": "Task CRUD API", "status": "done" }
              ],
              "blocks": [
                { "storyId": "S-3.2", "title": "Focus Mode UI" }
              ],
              "relatedStories": ["S-2.2"]
            },
            "notes": "Performance is critical — must handle 500 cards without jank on mid-range hardware."
          },
          {
            "id": "S-1.3",
            "title": "Dependency Graph Visualization",
            "userStory": {
              "asA": "Engineering Manager",
              "iWant": "to see an interactive visual graph of task dependencies",
              "soThat": "I can identify critical path items and unblock my team",
              "formatted": "As an Engineering Manager, I want to see an interactive visual graph of task dependencies, so that I can identify critical path items and unblock my team."
            },
            "acceptanceCriteria": [
              { "id": "AC-1.3.1", "given": "tasks have dependency relationships", "when": "I open the dependency view", "then": "a directed graph shows tasks as nodes and dependencies as edges" },
              { "id": "AC-1.3.2", "given": "a task is blocked", "when": "I click on it in the graph", "then": "the blocking chain is highlighted in red" },
              { "id": "AC-1.3.3", "given": "the graph is displayed", "when": "I hover over a node", "then": "a tooltip shows task details, assignee, and estimated completion" }
            ],
            "status": "draft",
            "storyPoints": 8,
            "priority": "should-have",
            "assignee": "Casey Lin",
            "requirementRefs": ["FR-4"],
            "uxReferences": ["wireframe-dependency-graph-v1.fig"],
            "testCases": ["TC-1.3.1", "TC-1.3.2", "TC-1.3.3"],
            "implementationDetails": [
              "d3-dag library for directed acyclic graph layout computation",
              "React SVG rendering for interactive nodes and edges",
              "Critical path highlighting algorithm using topological sort"
            ],
            "dependencies": {
              "blockedBy": [
                { "storyId": "S-1.1", "title": "Task CRUD API", "status": "done" }
              ],
              "blocks": [],
              "relatedStories": ["S-2.2"]
            }
          }
        ],
        "useCases": [
          {
            "id": "UC-01",
            "title": "Daily Task Triage",
            "summary": "Engineer reviews and prioritizes their task queue at the start of each day",
            "primaryActor": "Software Engineer",
            "secondaryActors": ["TaskFlow AI Engine"],
            "preconditions": ["Engineer has an active TaskFlow account", "At least 5 tasks are assigned to the engineer"],
            "trigger": "Engineer opens the TaskFlow Pro dashboard at the start of their workday",
            "scenario": {
              "context": "Engineer starts their workday and needs to know what to focus on",
              "before": "Engineer checks Slack, email, Jira, and calendar to piece together priorities",
              "after": "Engineer opens TaskFlow, sees AI-sorted task list, and starts working within 2 minutes",
              "impact": "Saves 20 minutes daily per engineer on task triage"
            },
            "mainFlow": [
              { "step": 1, "action": "Engineer opens TaskFlow Pro dashboard", "actor": "Software Engineer" },
              { "step": 2, "action": "System displays AI-prioritized task list for the day", "actor": "System" },
              { "step": 3, "action": "Engineer reviews top 3 tasks and adjusts if needed", "actor": "Software Engineer" },
              { "step": 4, "action": "Engineer clicks 'Start Focus' to begin work on the top task", "actor": "Software Engineer" }
            ],
            "alternativeFlows": [
              {
                "id": "AF-01-1",
                "name": "Manual Priority Override",
                "branchPoint": "Step 3",
                "steps": ["Engineer disagrees with AI ranking and manually reorders tasks", "System records the override as training data for the AI model"]
              }
            ],
            "exceptionFlows": [
              {
                "id": "EF-01-1",
                "name": "No Tasks Assigned",
                "trigger": "Engineer has zero tasks in their queue",
                "handling": "System shows a 'No tasks assigned' message with a link to the team backlog for self-assignment"
              }
            ],
            "postconditions": ["Task status updated to in-progress", "Focus timer started", "Notifications batched"],
            "businessRules": ["AI priority considers deadline proximity, dependency blocking count, and effort estimate"],
            "relatedRequirements": ["FR-1", "FR-2"],
            "relatedEpic": "EPIC-1",
            "relatedStories": ["S-1.1", "S-1.2"],
            "sourceDocument": "PRD.md#daily-workflow",
            "notes": "This is the most common user journey — optimizing this flow is critical for adoption."
          }
        ],
        "fitCriteria": {
          "functional": [
