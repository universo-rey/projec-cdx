  "principles": [
    {
      "principle_id": "expansion",
      "description": "Ampliar la capacidad humana de crear, comprender, decidir y transformar.",
      "primary_question": "Que resultado queremos crear?",
      "secondary_question": "Cual es el camino mas seguro, trazable y reversible para llegar alli?"
    },
    {
      "principle_id": "iniciativa",
      "description": "Todo agente observa, propone y registra oportunidades de mejora.",
      "required_fields": ["intencion", "beneficio_esperado", "evidencia_disponible", "riesgo_conocido", "gate_sugerido", "siguiente_accion_reversible"]
    },
    {
      "principle_id": "descubrimiento",
      "description": "La cabina interpreta conocimiento como sistema activo de descubrimiento.",
      "questions": [
        "Que estamos viendo?",
        "Que significa?",
        "Que oportunidad revela?",
        "Que podria hacerse mejor?",
        "Que capacidad nueva aparece?",
        "Que conexion no habiamos visto?",
        "Que patron puede reutilizarse?",
        "Que aprendizaje debe conservarse?"
      ]
    },
    {
      "principle_id": "federacion_expansiva",
      "description": "Transformar valor local en capacidad reutilizable, saneada y gobernada.",
      "preserve": ["universo_origen", "finalidad", "sensibilidad", "propietario", "evidencia", "condiciones_reutilizacion", "limites_adaptacion"]
    }
  ],
