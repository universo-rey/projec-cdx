(function () {
  "use strict";

  window.SDU_LIVE_LOADED = true;
  console.assert(window.SDU_LIVE_LOADED, "SDU live loader must be active");

  const STATE_URLS = [
    "/core/noc/noc-state.json",
    "/data/sdu-system-state.json",
    "/public/data/sdu-system-state.json"
  ];

  const BUS_URLS = [
    "/watchdog/bus/sdu-event-bus.jsonl",
    "/data/sdu-event-bus.jsonl",
    "/public/data/sdu-event-bus.jsonl"
  ];

  const LOCK_URLS = [
    "/core/noc/noc.lock.json"
  ];

  const SYSTEM_MAP_URLS = [
    "/core/noc/SYSTEM_MAP.json",
    "/config/actions_live_catalog.json"
  ];

  const ACTION_API_BASE = window.SDU_ACTION_API_BASE || ((window.location && window.location.origin && window.location.origin !== "null") ? window.location.origin : "http://127.0.0.1:5500");
  const NOC_EVENT_API = "/api/noc/events";

  const STATE_REFRESH_MS = 5000;
  const BUS_REFRESH_MS = 2000;
  const MAX_BUS_EVENTS = 12;

  const runtime = {
    state: null,
    stateSource: "",
    stateText: "",
    stateError: "",
    busEvents: [],
    busSource: "",
    busText: "",
    busRawTail: "",
    busError: "",
    busCursor: 0,
    lock: null,
    lockText: "",
    lockSource: "",
    lockError: "",
    lockState: "UNLOCKED",
    showTechnical: true,
    showBusRaw: true,
    showDiagnostic: false,
    diagnosticArmed: false,
    systemMap: null,
    systemMapText: "",
    systemMapSource: "",
    systemMapError: "",
    actionCatalog: [],
    refreshCounter: 0,
    lastUpdatedAt: null,
    hasRendered: false,
    lastG2EventSignature: ""
  };

  const root = ensureRoot();

  function ensureRoot() {
    let el = document.getElementById("sdu-live-root");
    if (!el) {
      el = document.createElement("main");
      el.id = "sdu-live-root";
      document.body.appendChild(el);
    }
    el.classList.add("sdu-app");
    return el;
  }

  function text(value) {
    return value === null || value === undefined || value === "" ? "—" : String(value);
  }

  function escapeHtml(value) {
    return text(value)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function humanize(value) {
    const raw = text(value).trim();
    if (!raw || raw === "—") return "Sin datos";
    return raw
      .replace(/[_-]+/g, " ")
      .replace(/\s+/g, " ")
      .trim()
      .split(" ")
      .map((part) => {
        if (/^[A-Z0-9]{2,}$/.test(part)) return part;
        return part.charAt(0).toUpperCase() + part.slice(1).toLowerCase();
      })
      .join(" ");
  }

  function get(obj, path, fallback = null) {
    let current = obj;
    for (const key of path) {
      if (!current || typeof current !== "object" || !(key in current)) {
        return fallback;
      }
      current = current[key];
    }
    return current === undefined || current === null ? fallback : current;
  }

  function friendlyStatus(value) {
    const token = text(value).trim().toUpperCase();
    if (token.startsWith("PASS")) return "Aprobado";
    if (token.startsWith("FAIL")) return "Fallido";
    if (token.startsWith("WARNING")) return "Atención";
    if (token.startsWith("ROOT_JUNCTION")) return "Raíz verificada";
    if (token.startsWith("MULTIREPO")) return "Multirepositorio";
    const map = {
      OK: "Correcto",
      PASS: "Aprobado",
      PASSED: "Aprobado",
      PASSING: "En curso",
      HEALTHY: "Saludable",
      ACTIVE: "Activo",
      ACTIVATING: "Activando",
      READY: "Listo",
      LOADED: "Cargado",
      CARGADA: "Cargada",
      CARGADO: "Cargado",
      WARNING: "Atención",
      WARN: "Atención",
      VIOLATION: "Revisión requerida",
      FAIL: "Fallido",
      FAILED: "Fallido",
      ERROR: "Error",
      DEGRADED: "Degradado",
      NOC_OPERATIONAL: "Operativo",
      NOC_ATTENTION_REQUIRED: "Atención requerida",
      ATTENTION_REQUIRED: "Atención requerida",
      SDU_OBSERVABILITY_HARDENED: "Observabilidad endurecida",
      BLOCKED: "Bloqueado",
      PREPARAR: "Preparar",
      PREPARING: "Preparando",
      PREPARED: "Preparado",
      READY_FOR_REVIEW: "Listo para revisar",
      ACTION_REQUIRED: "Acción requerida",
      PENDING_ACTION: "Acción pendiente",
      NO_CHANGE: "Sin cambios",
      CHANGE_DETECTED: "Cambio detectado",
      NOC_OPERATIONAL: "Operativo",
      NOC_ATTENTION_REQUIRED: "Atención requerida",
      ATTENTION_REQUIRED: "Atención requerida",
      SDU_OBSERVABILITY_HARDENED: "Observabilidad endurecida",
      LOG_ONLY: "Solo registro",
      READ_ONLY: "Solo lectura",
      READ_ONLY_TELEMETRY: "Telemetría de solo lectura",
      CONTROLLED_LOOP: "Bucle controlado",
      AUTO: "Automático",
      MANUAL: "Manual",
      HIGH: "Alta",
      MEDIUM: "Media",
      LOW: "Baja"
    };
    return map[token] || humanize(token);
  }

  function friendlyDecision(value) {
    const token = text(value).trim().toUpperCase();
    if (token.startsWith("PASS")) return "Aprobado";
    if (token.startsWith("FAIL")) return "Fallido";
    if (token.startsWith("WARNING")) return "Atención";
    if (token.startsWith("ROOT_JUNCTION")) return "Raíz validada";
    if (token.startsWith("MULTIREPO")) return "Multirepositorio";
    const map = {
      OK: "Correcto",
      PASS: "Aprobado",
      FAIL: "Fallido",
      PREPARAR: "Preparar",
      PREPARED: "Preparado",
      READY_FOR_REVIEW: "Listo para revisar",
      ACTION_REQUIRED: "Requiere acción",
      PENDING_ACTION: "Acción pendiente",
      VIOLATION: "Revisión requerida",
      WARNING: "Atención",
      NO_CHANGE: "Sin cambios",
      CHANGE_DETECTED: "Cambio detectado",
      LOG_ONLY: "Solo registro",
      READ_ONLY_TELEMETRY: "Telemetría de solo lectura",
      CONTROLLED_LOOP: "Bucle controlado",
      RUNNING: "En ejecución",
      ACTIVE: "Activo",
      ACTIVE_EVIDENCE: "Evidencia activa",
      ROOT_JUNCTION_HYGIENE_FINAL_PASS: "Raíz validada",
      SDU_G50_PACKAGE_ACTIVATED: "Paquete SDU activado",
      SDU_MULTIREPO_LAYER_INTEGRATED: "Multirepositorio integrado",
      SDU_REPO_BOOT_PROMPTS_INTEGRATED: "Arranque de repos integrado",
      SDU_REPO_BOOT_PROMPTS_LAYER_CLOSED: "Capa de arranque cerrada",
      CHAIN_REQUIRED: "Cadena requerida",
      DECLARATIVE_REQUIRED: "Declarativo requerido",
      PREFERRED_FOR_MULTI_STEP: "Preferido para multi paso",
      EXISTING_RECIPE: "Receta existente",
      EXISTING_SKILL: "Skill existente",
      AGENT_PLAN: "Plan de agente",
      NEW_SKILL_CREATION: "Nueva skill"
    };
    return map[token] || humanize(token);
  }

  function friendlySeverity(value) {
    const token = text(value).trim().toUpperCase();
    const map = {
      HIGH: "Alta",
      MEDIUM: "Media",
      LOW: "Baja",
      CRITICAL: "Crítica",
      INFO: "Informativa",
      NONE: "Sin severidad"
    };
    return map[token] || friendlyStatus(token);
  }

  function toneForText(value) {
    const token = text(value).trim().toUpperCase();
    if (!token || token === "—" || token === "SIN DATOS") return "is-neutral";
    if (token.startsWith("PASS")) return "is-good";
    if (token.startsWith("FAIL")) return "is-bad";
    if (token.startsWith("WARNING")) return "is-warn";
    if (token.startsWith("ROOT_JUNCTION")) return "is-good";
    if (token.startsWith("MULTIREPO")) return "is-warn";
    if (["OK", "PASS", "ACTIVE", "READY", "HEALTHY", "LOADED", "CARGADA", "CARGADO", "PREPARADO"].includes(token)) {
      return "is-good";
    }
    if (["HIGH", "WARNING", "VIOLATION", "PENDING_ACTION", "ACTION_REQUIRED", "ATTENTION_REQUIRED", "NOC_ATTENTION_REQUIRED", "READY_FOR_REVIEW", "MEDIUM", "PREPARAR"].includes(token)) {
      return "is-warn";
    }
    if (["FAIL", "FAILED", "ERROR", "DEGRADED", "BLOCKED", "CRITICAL", "SIN_CARPETA", "SIN_RESPONSABLE", "INCONSISTENTE"].includes(token)) {
      return "is-bad";
    }
    if (["ACTIVE", "RUNNING", "LOG_ONLY", "CONTROLLED_LOOP", "READ_ONLY_TELEMETRY", "INFO", "NOC_OPERATIONAL"].includes(token)) {
      return "is-info";
    }
    return "is-neutral";
  }

  function toneForScore(score) {
    const value = Number(score);
    if (!Number.isFinite(value)) return "is-neutral";
    if (value >= 85) return "is-good";
    if (value >= 65) return "is-warn";
    return "is-bad";
  }

  function formatDateTime(value) {
    if (!value) return "—";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return text(value);
    return new Intl.DateTimeFormat("es-AR", {
      dateStyle: "short",
      timeStyle: "medium"
    }).format(date);
  }

  function formatDuration(value) {
    if (value === null || value === undefined || value === "") return "—";
    const ms = Number(value);
    if (!Number.isFinite(ms)) return text(value);
    if (ms < 1000) return `${Math.round(ms)} ms`;
    return `${(ms / 1000).toFixed(ms >= 10000 ? 0 : 1)} s`;
  }

  function normalizeAction(action) {
    if (!action || typeof action !== "object") return null;
    const id = text(action.actionId || action.id).trim();
    if (!id) return null;
    return {
      ...action,
      id,
      actionId: id
    };
  }

  function extractActionCatalog(systemMap) {
    if (Array.isArray(systemMap)) {
      return systemMap.map(normalizeAction).filter(Boolean);
    }
    if (!systemMap || typeof systemMap !== "object") return [];
    const candidates = systemMap.actions || systemMap.actionCatalog || systemMap.catalog;
    if (!Array.isArray(candidates)) return [];
    return candidates.map(normalizeAction).filter(Boolean);
  }

  async function fetchFirstText(urls) {
    let lastError = null;
    for (const url of urls) {
      try {
        const response = await fetch(`${url}?t=${Date.now()}`, { cache: "no-store" });
        if (!response.ok) {
          lastError = new Error(`${url} -> HTTP ${response.status}`);
          continue;
        }
        return { url, text: await response.text() };
      } catch (error) {
        lastError = error;
      }
    }
    throw lastError || new Error("No se encontró una fuente válida");
  }

  async function fetchFirstJson(urls) {
    let lastError = null;
    for (const url of urls) {
      try {
        const response = await fetch(`${url}?t=${Date.now()}`, { cache: "no-store" });
        if (!response.ok) {
          lastError = new Error(`${url} -> HTTP ${response.status}`);
          continue;
        }
        const textValue = await response.text();
        const parsed = safeJson(textValue);
        if (parsed && parsed.__error) {
          lastError = new Error(`${url} -> JSON inválido: ${parsed.__error}`);
          continue;
        }
        return { url, text: textValue, data: parsed };
      } catch (error) {
        lastError = error;
      }
    }
    throw lastError || new Error("No se encontró un JSON válido");
  }

  function safeJson(textValue) {
    try {
      return JSON.parse(textValue);
    } catch (error) {
      return { __error: error.message, __raw: textValue };
    }
  }

  function clone(value) {
    return value === null || value === undefined ? value : JSON.parse(JSON.stringify(value));
  }

  function summarizeChange(change) {
    if (!change) return "Sin cambios";
    const parts = [];
    if (change.type) parts.push(friendlyDecision(change.type));
    if (change.severity) parts.push(`Severidad ${friendlySeverity(change.severity)}`);
    if (change.detected === false) parts.push("Sin delta");
    if (change.deltas) {
      const deltaParts = [];
      for (const key of ["total", "high", "medium", "low", "actions"]) {
        if (change.deltas[key] === undefined || change.deltas[key] === null) continue;
        deltaParts.push(`${key}:${change.deltas[key]}`);
      }
      if (deltaParts.length) parts.push(deltaParts.join(" · "));
    }
    return parts.join(" · ") || "Sin cambios";
  }

  function summarizeNocState(noc) {
    if (!noc || typeof noc !== "object") return "NOC sin datos";
    const total = text(noc.total_expedientes);
    const ok = text(noc.expedientes_ok);
    const error = text(noc.expedientes_con_error);
    const folder = text(noc.sin_carpeta);
    const owner = text(noc.sin_responsable);
    const general = friendlyStatus(noc.estado_general);
    return `Expedientes ${total} · OK ${ok} · Con error ${error} · Sin carpeta ${folder} · Sin responsable ${owner} · Estado ${general}`;
  }

  function toneForEntrypoint(status) {
    const token = text(status).trim().toUpperCase();
    if (token === "CANONICAL") return "is-good";
    if (token === "CORRECTED" || token === "OBSERVED") return "is-warn";
    return "is-bad";
  }

  function entrypointLabel(status) {
    const token = text(status).trim().toUpperCase();
    if (token === "CANONICAL") return "CWD canonico";
    if (token === "CORRECTED") return "CWD corregido";
    if (token === "OBSERVED") return "CWD observado";
    return "Entrada fuera de control";
  }

  function summarizeEntrypoint(entrypoint) {
    if (!entrypoint || typeof entrypoint !== "object") return "Sin datos de entrypoint";
    const cwd = text(entrypoint.current_cwd);
    const canonical = text(entrypoint.canonical_root);
    const status = entrypointLabel(entrypoint.status);
    const last = entrypoint.last_event_timestamp ? formatDateTime(entrypoint.last_event_timestamp) : "—";
    return `cwd ${cwd} · canon ${canonical} · ${status} · último evento ${last}`;
  }

  function renderCriticalExpediente(item) {
    const issueFlags = Array.isArray(item.issue_flags) ? item.issue_flags : [];
    const flagChips = issueFlags.map((flag) => `<span class="sdu-chip ${toneForText(flag)}">${escapeHtml(flag)}</span>`).join("");
    const sourceFlags = item.source_flags && typeof item.source_flags === "object"
      ? Object.keys(item.source_flags).filter((key) => item.source_flags[key]).map((key) => `<span class="sdu-chip is-info">${escapeHtml(key)}</span>`).join("")
      : "";
    const title = item.title || item.task_title || item.task_id || "Sin titulo";
    const detailLine = [
      item.task_id ? `Task ${item.task_id}` : null,
      item.plan_id ? `Plan ${item.plan_id}` : null,
      item.consistency_score !== undefined && item.consistency_score !== null ? `Score ${item.consistency_score}` : null,
      item.primary_comment_source ? `Comentarios ${item.primary_comment_source}` : null
    ].filter(Boolean).join(" · ");
    return `
      <article class="sdu-feed__item">
        <div class="sdu-feed__head">
          <div>
            <div class="sdu-feed__type">
              <span class="sdu-status-pill is-bad">CRITICO</span>
            </div>
            <div class="sdu-feed__source">${escapeHtml(item.status || "CRITICAL")}</div>
          </div>
          <div class="sdu-feed__time">${escapeHtml(item.readback_trust || "TRUSTED")}</div>
        </div>
        <div class="sdu-feed__body">${escapeHtml(title)}</div>
        <div class="sdu-feed__body">${escapeHtml(detailLine)}</div>
        <div class="sdu-card__foot">${flagChips}${sourceFlags}</div>
      </article>
    `;
  }

  function g2EventEmissionEnabled() {
    try {
      const params = new URLSearchParams(window.location.search || "");
      return params.get("g2events") === "1" || sessionStorage.getItem("SDU_NOC_G2_EVENTS_ENABLED") === "true";
    } catch {
      return false;
    }
  }

  function nocActionsEnabled() {
    try {
      const params = new URLSearchParams(window.location.search || "");
      return params.get("actions") === "1" || sessionStorage.getItem("SDU_NOC_ACTIONS_ENABLED") === "true";
    } catch {
      return false;
    }
  }

  function buildG2Governance(state) {
    const validation = get(state, ["governance", "multirepo", "validation"], {});
    const activationPlan = get(state, ["governance", "multirepo", "activation_plan"], {});
    const repos = Array.isArray(validation.repos) ? validation.repos : [];
    const sourceReady = Array.isArray(validation.repos);
    const planItems = Array.isArray(activationPlan.items) ? activationPlan.items : [];
    const unrecognizedStatuses = new Set(["NOT_MATERIALIZED", "HISTORICAL_ONLY"]);
    const conflictStatuses = new Set(["POSSIBLE_ACTIVE_MATCH", "MULTIPLE_ACTIVE_CANDIDATES"]);
    const unrecognized = repos.filter((repo) => unrecognizedStatuses.has(text(repo.detected_status).toUpperCase()));
    const conflicts = repos.filter((repo) => conflictStatuses.has(text(repo.detected_status).toUpperCase()));
    const planByRepo = new Map(planItems.map((item) => [text(item.repo), item]));

    return {
      validation,
      activationPlan,
      unrecognized,
      conflicts,
      planByRepo,
      sourceReady,
      dr0001: {
        status: sourceReady ? (validation.status || activationPlan.status || "OBSERVED") : "G2_SOURCE_INCOMPLETE",
        decision: sourceReady ? (validation.decision || activationPlan.status || "PREPARAR") : "PAUSADO",
        recognized: Number(validation.found || 0),
        expected: Number(validation.expected_total || repos.length || 0),
        violations: Array.isArray(validation.violations) ? validation.violations : []
      }
    };
  }

  function renderRepoGovernanceItem(repo, planByRepo, tone) {
    const plan = planByRepo.get(text(repo.repo)) || {};
    const paths = []
      .concat(Array.isArray(repo.active_paths) ? repo.active_paths : [])
      .concat(Array.isArray(repo.active_possible_paths) ? repo.active_possible_paths : [])
      .concat(Array.isArray(repo.historical_paths) ? repo.historical_paths : [])
      .slice(0, 2);
    const pathLine = paths.length ? paths.join(" · ") : "Sin path operativo reconocido";
    const requiredDecision = plan.required_decision || repo.required_decision || "RECONOCIMIENTO_REQUERIDO";
    return `
      <article class="sdu-governance-item">
        <div class="sdu-governance-item__head">
          <strong>${escapeHtml(repo.repo || repo.local_hint || "Repo sin nombre")}</strong>
          <span class="sdu-status-pill ${tone}">${escapeHtml(friendlyDecision(repo.detected_status || plan.current_status || "OBSERVED"))}</span>
        </div>
        <div class="sdu-governance-item__body">${escapeHtml(pathLine)}</div>
        <div class="sdu-card__foot">
          <span class="sdu-chip is-info">${escapeHtml(repo.ring_id || "ANILLO pendiente")}</span>
          <span class="sdu-chip is-warn">${escapeHtml(friendlyDecision(requiredDecision))}</span>
        </div>
      </article>
    `;
  }

  function renderG2DecreePanel(state) {
    const g2 = buildG2Governance(state);
    const recognizedLabel = g2.dr0001.expected ? `${g2.dr0001.recognized}/${g2.dr0001.expected}` : "Sin matriz";
    const subordinationTone = g2.dr0001.decision === "PASS" || g2.dr0001.status === "PASS" ? "is-good" : "is-warn";
    const violations = !g2.sourceReady
      ? `<span class="sdu-chip is-warn">Matriz G2 incompleta en fuente activa</span>`
      : g2.dr0001.violations.length
      ? g2.dr0001.violations.map((item) => `<span class="sdu-chip is-warn">${escapeHtml(item)}</span>`).join("")
      : `<span class="sdu-chip is-good">Sin violaciones multirepo declaradas</span>`;
    const unrecognizedItems = g2.unrecognized.length
      ? g2.unrecognized.slice(0, 8).map((repo) => renderRepoGovernanceItem(repo, g2.planByRepo, "is-bad")).join("")
      : `<div class="sdu-feed__empty">Sin artefactos no reconocidos en la matriz visible.</div>`;
    const conflictItems = g2.conflicts.length
      ? g2.conflicts.slice(0, 8).map((repo) => renderRepoGovernanceItem(repo, g2.planByRepo, "is-warn")).join("")
      : `<div class="sdu-feed__empty">Sin conflictos activos en la matriz visible.</div>`;

    return `
      <section class="sdu-decree-grid" aria-label="SDU NOC G2 Decreto DR-0001">
        <div class="sdu-panel sdu-decree-panel">
          <div class="sdu-panel__title">
            <span>Estado SDU</span>
            <strong>${escapeHtml(friendlyStatus(g2.dr0001.status))}</strong>
          </div>
          <div class="sdu-decree-metric">
            <span>Reconocidos</span>
            <strong>${escapeHtml(recognizedLabel)}</strong>
          </div>
          <div class="sdu-decree-metric">
            <span>Decisión DR-0001</span>
            <strong class="${subordinationTone}">${escapeHtml(friendlyDecision(g2.dr0001.decision))}</strong>
          </div>
          <div class="sdu-card__foot">${violations}</div>
        </div>

        <div class="sdu-panel sdu-decree-panel">
          <div class="sdu-panel__title">
            <span>No reconocidos por SDU</span>
            <strong>${escapeHtml(String(g2.unrecognized.length))}</strong>
          </div>
          <div class="sdu-governance-list">${unrecognizedItems}</div>
        </div>

        <div class="sdu-panel sdu-decree-panel">
          <div class="sdu-panel__title">
            <span>En conflicto</span>
            <strong>${escapeHtml(String(g2.conflicts.length))}</strong>
          </div>
          <div class="sdu-governance-list">${conflictItems}</div>
        </div>

        <div class="sdu-panel sdu-decree-panel">
          <div class="sdu-panel__title">
            <span>Subordinación a DR-0001</span>
            <strong class="${subordinationTone}">C6 operativo</strong>
          </div>
          <div class="sdu-feed__body">Lo no reconocido queda fuera de operación hasta reconocimiento, decisión o activación declarada.</div>
          <div class="sdu-card__foot">
            <span class="sdu-chip is-info">CE-001 reconocimiento</span>
            <span class="sdu-chip is-warn">CE-002 conflictos</span>
            <span class="sdu-chip ${g2EventEmissionEnabled() ? "is-info" : "is-neutral"}">${g2EventEmissionEnabled() ? "eventos habilitados" : "eventos pausados"}</span>
            <span class="sdu-chip ${g2.sourceReady ? "is-info" : "is-warn"}">${g2.sourceReady ? "matriz completa" : "sin emisión G2"}</span>
            <span class="sdu-chip ${subordinationTone}">${escapeHtml(friendlyDecision(g2.activationPlan.status || "ACTION_REQUIRED"))}</span>
          </div>
        </div>
      </section>
    `;
  }

  async function emitLocalNocEvent(type, payload = {}) {
    const event = {
      timestamp: new Date().toISOString(),
      type,
      payload
    };
    try {
      const response = await fetch(NOC_EVENT_API, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-SDU-NOC-Producer": "sdu-live-g2"
        },
        body: JSON.stringify(event)
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return true;
    } catch (error) {
      console.warn("SDU NOC local event paused or failed", error);
      return false;
    }
  }

  function summarizeState(state) {
    const health = get(state, ["health"], {});
    const telemetry = get(state, ["telemetry", "resume"], {});
    const change = get(state, ["last_change"], {});
    const alert = get(state, ["last_alert"], {});
    const run = get(state, ["last_run"], {});
    const governance = get(state, ["governance"], {});
    const multirepo = get(governance, ["multirepo"], {});
