  async function executeNocAction(actionId) {
    if (!nocActionsEnabled()) {
      toast("Acciones NOC pausadas por contención.");
      return;
    }
    const action = runtime.actionCatalog.find((item) => String(item.id) === String(actionId) || String(item.actionId) === String(actionId));
    if (!action) {
      toast("Accion no encontrada.");
      return;
    }
    if (isRuntimeLocked()) {
      const lockSummary = buildLockSummary();
      const feedback = document.getElementById("sdu-action-feedback");
      if (feedback) {
        feedback.textContent = lockSummary;
      }
      toast(lockSummary);
      return;
    }
    const confirmed = window.confirm(`Ejecutar ${action.label || action.id} via /action/${action.id}?`);
    if (!confirmed) {
      toast("Ejecucion cancelada.");
      return;
    }
    const feedback = document.getElementById("sdu-action-feedback");
    if (feedback) {
      feedback.textContent = `Ejecutando ${action.label || action.id}...`;
    }
    const lastEvent = runtime.busEvents.length ? runtime.busEvents[runtime.busEvents.length - 1] : null;
    const eventId = get(lastEvent, ["payload", "eventId"], "") || get(lastEvent, ["eventId"], "") || "";
    try {
      const response = await fetch(`${ACTION_API_BASE}/action/${encodeURIComponent(action.id)}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          actionId: action.id,
          eventId,
          executedBy: "SDU_LIVE",
          decisionSource: "ACTION_ROUTE",
          confirmationMode: "INLINE_BUTTON"
        })
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok || result.ok === false) {
        throw new Error(result.error || `HTTP ${response.status}`);
      }
      if (feedback) {
        feedback.textContent = `Accion ejecutada correctamente\n${result.timestamp || new Date().toISOString()} | ${action.label || action.id}`;
      }
      toast(`Accion NOC ejecutada: ${action.label || action.id}.`);
      await refreshAll({ force: true, silent: true });
    } catch (error) {
      if (feedback) {
        feedback.textContent = `Error de ejecucion: ${error.message || error}`;
      }
      toast(`No se pudo ejecutar ${action.label || action.id}.`);
    }
  }

