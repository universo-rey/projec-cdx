  function buildDiagnosticText(state) {
    const health = get(state, ["health"], {});
    const telemetry = get(state, ["telemetry", "resume"], {});
    const noc = get(state, ["noc"], {});
    const busCount = runtime.busEvents.length;
    const readyForG8 = Number(health.score || 0) >= 70;
    const lines = [
      "Diagnóstico preparado para G8. Sin ejecución automática.",
      `Salud actual: ${text(health.score)}/100 (${friendlyStatus(health.status)})`,
      `Watchdog: ${friendlyStatus(telemetry.status)} · ${summarizeChange(telemetry.change)}`,
      `NOC: ${summarizeNocState(noc)}`,
      `Bus de eventos visible: ${busCount} eventos`,
      `Mapa canonico: ${runtime.systemMapSource || "sin fuente"} · ${runtime.actionCatalog.length} acciones`,
      `Panel listo para acción real: ${readyForG8 ? "Sí, con control manual" : "Pendiente de estabilización"}`,
      "Las acciones de este panel solo preparan enlaces y lecturas. No ejecutan scripts.",
      `Copia del estado: ${runtime.stateSource || "sin fuente"}`,
      `Copia del bus: ${runtime.busSource || "sin fuente"}`
    ];
    return lines.join("\n");
