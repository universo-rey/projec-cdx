  function eventTone(type, payload) {
    const token = text(type).trim().toUpperCase();
    if (token === "WATCHDOG_ALERT") {
      return toneForText(get(payload, ["severity"], "WARNING"));
    }
    if (token === "ROOT_JUNCTION_PASS") return "is-good";
    if (token === "MULTIREPO_VALIDATION") return "is-warn";
    if (token === "CODEX_EXECUTION_MODE_ACTIVE") return "is-good";
    if (token === "SDU_EXECUTION_CHAIN_VIOLATION") return "is-bad";
    if (token === "SDU_NOC_ERROR_DETECTED") return "is-bad";
    if (token === "SDU_NOC_AUTO_FIX") return "is-good";
    if (token === "SDU_NOC_VALIDATION_RESULT") return "is-info";
    if (token === "SDU_NOC_ACTION_EXECUTED") return "is-info";
    if (["SDU_AGENT_SELECTED", "SDU_SKILL_INVOKED", "SDU_TOOL_EXECUTED", "SDU_ACTION_VALIDATED"].includes(token)) return "is-info";
    if (token === "WATCHDOG_RUN") return "is-info";
    if (token === "SDU_STATE_UPDATED") return "is-neutral";
    return "is-neutral";
  }

  function eventLabel(type) {
    const token = text(type).trim().toUpperCase();
    const map = {
      SDU_STATE_UPDATED: "Estado actualizado",
      WATCHDOG_ALERT: "Alerta del watchdog",
      WATCHDOG_RUN: "Corrida del watchdog",
      MULTIREPO_VALIDATION: "Validación multirepositorio",
      CODEX_EXECUTION_MODE_ACTIVE: "Modo Codex activo",
      SDU_EXECUTION_CHAIN_VIOLATION: "Violación de cadena de ejecución",
      SDU_AGENT_SELECTED: "Agente seleccionado",
      SDU_SKILL_INVOKED: "Skill invocada",
      SDU_TOOL_EXECUTED: "Tool ejecutada",
      SDU_ACTION_VALIDATED: "Acción validada",
      SDU_NOC_ACTION_EXECUTED: "Acción NOC ejecutada",
      SDU_NOC_VALIDATION_RESULT: "Validación NOC",
      SDU_NOC_ERROR_DETECTED: "Error NOC detectado",
      SDU_NOC_AUTO_FIX: "Auto fix NOC",
      ROOT_JUNCTION_PASS: "Raíz verificada"
    };
    return map[token] || friendlyDecision(token);
  }

  function describeBusPayload(event) {
    const payload = get(event, ["payload"], {});
    if (typeof payload === "string") return payload;
    if (payload && typeof payload === "object") {
      if (payload.summary) return text(payload.summary);
      const ordered = [];
      for (const key of ["summary", "message", "note", "status", "decision", "severity", "traceId", "runId"]) {
        if (payload[key] === undefined || payload[key] === null || payload[key] === "") continue;
        ordered.push(`${key}: ${text(payload[key])}`);
      }
      if (ordered.length) return ordered.join(" · ");
      return JSON.stringify(payload, null, 2);
    }
    return "Sin detalle";
  }

  function renderBusItem(event) {
    const payload = get(event, ["payload"], {});
    return `
      <article class="sdu-feed__item">
        <div class="sdu-feed__head">
          <div>
            <div class="sdu-feed__type">
              <span class="sdu-status-pill ${eventTone(event.type, payload)}">${escapeHtml(eventLabel(event.type))}</span>
