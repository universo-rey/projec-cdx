  async function refreshState(options = {}) {
    const force = Boolean(options.force);
    try {
      const result = await fetchFirstText(STATE_URLS);
      if (!force && result.text === runtime.stateText) {
        return false;
      }

      const parsed = safeJson(result.text);
      if (parsed && parsed.__error) {
        runtime.stateError = `Estado JSON inválido: ${parsed.__error}`;
        return false;
      }

      runtime.stateText = result.text;
      runtime.state = parsed;
      runtime.stateSource = result.url;
      runtime.stateError = "";
      runtime.lastUpdatedAt = new Date().toISOString();
      return true;
    } catch (error) {
      runtime.stateError = error.message || "No se pudo leer el estado";
      return false;
    }
  }

  async function refreshBus(options = {}) {
    const force = Boolean(options.force);
    try {
      const result = await fetchFirstText(BUS_URLS);
      if (!force && result.text === runtime.busText) {
        return false;
      }

      const lines = result.text.split(/\r?\n/).filter((line) => line.trim().length > 0);
      if (runtime.busCursor > lines.length) {
        runtime.busCursor = 0;
        runtime.busEvents = [];
      }

      const start = runtime.busCursor === 0 ? 0 : runtime.busCursor;
      const newLines = lines.slice(start);
      const parsedNew = [];
      for (const line of newLines) {
        try {
          const parsed = JSON.parse(line);
          parsedNew.push(parsed);
        } catch {
          // Skip malformed bus lines and keep the panel alive.
        }
      }

      if (runtime.busCursor === 0) {
        runtime.busEvents = parsedNew.slice(-MAX_BUS_EVENTS);
      } else if (parsedNew.length) {
        runtime.busEvents = runtime.busEvents.concat(parsedNew).slice(-MAX_BUS_EVENTS);
      }

      runtime.busCursor = lines.length;
      runtime.busText = result.text;
      runtime.busSource = result.url;
      runtime.busRawTail = lines.slice(-20).join("\n");
      runtime.busError = "";
      runtime.lastUpdatedAt = new Date().toISOString();
      return true;
    } catch (error) {
      runtime.busError = error.message || "No se pudo leer el bus";
      return false;
    }
  }

  async function refreshLock(options = {}) {
    const force = Boolean(options.force);
    try {
      const result = await fetchFirstJson(LOCK_URLS);
      if (!force && result.text === runtime.lockText) {
        return false;
      }

      runtime.lockText = result.text;
      runtime.lock = result.data;
      runtime.lockSource = result.url;
      runtime.lockError = "";
      runtime.lockState = "LOCKED";
      runtime.lastUpdatedAt = new Date().toISOString();
      return true;
    } catch (error) {
      const message = error.message || "No se pudo leer el lock";
      if (message.includes("HTTP 404")) {
        const changed = runtime.lockState !== "UNLOCKED" || runtime.lock !== null || runtime.lockText || runtime.lockSource || runtime.lockError;
        runtime.lock = null;
        runtime.lockText = "";
        runtime.lockSource = "";
        runtime.lockError = "";
        runtime.lockState = "UNLOCKED";
        return Boolean(changed);
      }
      runtime.lock = null;
      runtime.lockText = "";
      runtime.lockSource = "";
      runtime.lockError = message;
      runtime.lockState = "UNKNOWN";
      return false;
    }
  }

  async function refreshSystemMap(options = {}) {
    const force = Boolean(options.force);
    try {
      const result = await fetchFirstJson(SYSTEM_MAP_URLS);
      if (!force && result.text === runtime.systemMapText) {
        return false;
      }

      runtime.systemMapText = result.text;
      runtime.systemMap = result.data;
      runtime.systemMapSource = result.url;
      runtime.actionCatalog = extractActionCatalog(result.data);
      runtime.systemMapError = "";
      runtime.lastUpdatedAt = new Date().toISOString();
      return true;
    } catch (error) {
      runtime.systemMapError = error.message || "No se pudo leer el mapa canonico";
      runtime.actionCatalog = [];
      return false;
    }
  }

  async function refreshAll(options = {}) {
    const force = Boolean(options.force);
    const results = await Promise.allSettled([
      refreshState({ force }),
      refreshBus({ force }),
      refreshLock({ force }),
      refreshSystemMap({ force })
    ]);
    const changed = results.some((item) => item.status === "fulfilled" && item.value);
    if (changed || !runtime.hasRendered) {
      render();
    }
    if (!options.silent) {
      toast("Panel actualizado.");
    }
  }

  async function resyncState() {
    const endpointAttempt = await tryLocalResyncEndpoint();
    await refreshAll({ force: true, silent: true });
    toast(endpointAttempt ? "Estado re-sincronizado desde el endpoint local." : "Re-sincronización simulada localmente.");
  }

  async function tryLocalResyncEndpoint() {
    const candidates = [
      "/api/resync-state",
      "/resync-state",
      "/api/sdu/resync"
    ];
    for (const url of candidates) {
      try {
        const response = await fetch(url, { method: "POST" });
        if (response.ok) return true;
      } catch {
        // Keep falling back to the simulated refresh.
      }
    }
    return false;
  }

  async function copySummary() {
    const summary = buildSummaryText();
    try {
      await navigator.clipboard.writeText(summary);
      toast("Resumen copiado.");
    } catch {
      const fallback = document.createElement("textarea");
      fallback.value = summary;
      fallback.setAttribute("readonly", "true");
      fallback.style.position = "fixed";
      fallback.style.opacity = "0";
      document.body.appendChild(fallback);
      fallback.select();
      try {
        document.execCommand("copy");
        toast("Resumen copiado.");
      } catch {
        toast("El navegador no permitió copiar.");
      }
      fallback.remove();
    }
  }

  function openValidationSource() {
    const servedUrl = runtime.stateSource || STATE_URLS[0];
    window.open(`${servedUrl}?t=${Date.now()}`, "_blank", "noopener,noreferrer");
    toast("Abriendo la copia servida del estado.");
  }

  async function downloadSnapshot() {
    const payload = {
      generatedAt: new Date().toISOString(),
      stateSource: runtime.stateSource,
      busSource: runtime.busSource,
      state: clone(runtime.state),
      busEvents: clone(runtime.busEvents),
      busRawTail: runtime.busRawTail,
      summary: buildSummaryText()
    };

    const jsonText = JSON.stringify(payload, null, 2);
    try {
      await navigator.clipboard.writeText(jsonText);
      toast("Snapshot copiado al portapapeles.");
      return;
    } catch {
      // Fallback below.
    }

    const blob = new Blob([jsonText], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const opened = window.open(url, "_blank", "noopener,noreferrer");
    setTimeout(() => URL.revokeObjectURL(url), 4000);
    toast(opened ? "Snapshot abierto en una pestaña nueva." : "No se pudo exportar el snapshot.");
  }

  async function bootstrap() {
    await Promise.allSettled([
      refreshState({ force: true }),
      refreshBus({ force: true }),
      refreshSystemMap({ force: true })
    ]);
    render();
    setInterval(() => refreshState({ force: false }).then((changed) => {
      if (changed) render();
    }), STATE_REFRESH_MS);
    setInterval(() => refreshBus({ force: false }).then((changed) => {
      if (changed) render();
    }), BUS_REFRESH_MS);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootstrap, { once: true });
  } else {
    bootstrap();
  }
})();

