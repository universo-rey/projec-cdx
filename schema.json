{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PROJEC CDX Metadata Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "categoria",
    "tipo",
    "estado",
    "version",
    "autoridad",
    "origen",
    "ubicacion_repo",
    "etiquetas",
    "relacionados",
    "descripcion"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "categoria": {
      "type": "string",
      "enum": [
        "operativa",
        "dataverse",
        "procesos",
        "playbooks",
        "recipes",
        "tests",
        "packages"
      ]
    },
    "tipo": {
      "type": "string",
      "enum": [
        "mapa",
        "indice",
        "matriz",
        "plan",
        "acta",
        "orden",
        "readback",
        "prompt",
        "reporte"
      ]
    },
    "estado": {
      "type": "string",
      "enum": [
        "borrador",
        "en_revision",
        "aprobado",
        "live"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "fecha_evento": {
      "type": "string",
      "format": "date"
    },
    "autoridad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tipo",
        "referencia"
      ],
      "properties": {
        "tipo": {
          "type": "string",
          "enum": [
            "owner",
            "equipo",
            "sistema",
            "externo"
          ]
        },
        "referencia": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "origen": {
      "type": "string",
      "enum": [
        "GitHub",
        "SharePoint",
        "Dataverse",
        "Mixto"
      ]
    },
    "ubicacion_repo": {
      "type": "string",
      "minLength": 1
    },
    "ubicacion_m365": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "siteUrl": {
          "type": "string",
          "minLength": 1
        },
        "driveId": {
          "type": "string",
          "minLength": 1
        },
        "listId": {
          "type": "string",
          "minLength": 1
        },
        "itemId": {
          "type": "string",
          "minLength": 1
        },
        "fileId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "etiquetas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relacionados": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "descripcion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    }
  }
}
