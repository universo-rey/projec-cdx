{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/event-worker.schema.json",
  "title": "CEO G2 Event Worker",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "worker_type",
    "description",
    "requires_policy_decision",
    "writes_trace"
  ],
  "properties": {
    "worker_type": {
      "type": "string",
      "enum": [
        "validation_worker",
        "policy_worker",
        "trace_worker",
        "evidence_worker",
        "replay_worker",
        "self_heal_worker"
      ]
    },
    "description": {
      "type": "string"
    },
    "requires_policy_decision": {
      "type": "boolean"
    },
    "writes_trace": {
      "type": "boolean"
    }
  }
}
