{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/event-result.schema.json",
  "title": "CEO G2 Event Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event_id",
    "state",
    "result",
    "timestamp",
    "worker",
    "evidence"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": [
        "OK",
        "WARN",
        "FAIL",
        "HOLD"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "worker": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "object",
      "required": [
        "required",
        "path"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
