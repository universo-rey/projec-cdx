{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/live-execution.schema.json",
  "title": "CEO G5 Live Execution Simulation",
  "type": "object",
  "additionalProperties": true,
  "required": ["execution_id", "live_action_id", "mode", "dry_run", "pre_state", "post_state", "result", "changes", "evidence_path", "rollback_plan_path", "executed_at"],
  "properties": {
    "execution_id": { "type": "string", "minLength": 1 },
    "live_action_id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "const": "LIVE_CONTROLLED_SIMULATED" },
    "dry_run": { "type": "boolean", "const": true },
    "pre_state": { "type": "object" },
    "post_state": { "type": "object" },
    "result": { "type": "string", "enum": ["SIMULATED", "BLOCKED", "FAILED"] },
    "changes": { "type": "array" },
    "evidence_path": { "type": "string", "minLength": 1 },
    "rollback_plan_path": { "type": "string", "minLength": 1 },
    "executed_at": { "type": "string", "format": "date-time" }
  }
}
