      "agentId": "orchestrator_agent",
      "owner": "thot-tecnico",
      "surface": "repo-local",
      "allowedActions": [
        "route",
        "emit-agent-decision-event",
        "plan-follow-up-event"
      ],
      "blockedActions": [
        "live-write",
        "secret-read",
        "production-mutation"
      ],
      "skill": "repo-agent-tool-governance",
      "recipe": "agentes-atomicos-algoritmicos-en-waves",
      "tool": "ceo-runtime-router.ps1",
      "evidence": "<RUNTIME_PATH>/bus/queue.jsonl",
      "validator": "ceo-validate-event.ps1",
      "stopCondition": "invalid event rejected fail-closed"
    },
    "contracts_agent": {
      "agentId": "contracts_agent",
      "owner": "seshat-normativa",
