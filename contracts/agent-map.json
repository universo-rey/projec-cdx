{
  "schemaVersion": "v1.5",
  "mode": "ACTIVE_GOVERNED_EXECUTION_BY_DEFAULT",
  "priorityModel": {
    "rule": "lower-number-wins; policy hold and validation/contracts failures stop the chain fail-closed",
    "tieBreaker": "sequence-then-agentId",
    "agentPriority": {
      "validation_agent": 1,
      "contracts_agent": 2,
      "path_sanitizer_agent": 2,
      "federation_enforcer_agent": 2,
      "sns_agent": 2,
      "vsi_execution_guard": 2,
      "orchestrator_agent": 3,
      "diagnostic_agent": 3,
      "control_plane_agent": 3,
      "bus_agent": 4,
      "optimization_agent": 4,
      "sanitizer_agent": 4,
      "observability_agent": 5,
      "evidence_agent": 6
    }
  },
  "agents": {
