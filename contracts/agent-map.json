      "skill": "repo-agent-tool-governance",
      "recipe": "cierre-wave-documental",
      "tool": "ceo-validate-event.ps1",
      "evidence": "contracts/contract-map.json",
      "validator": "run-contract-tests.ps1",
      "stopCondition": "schema critical missing"
    },
    "validation_agent": {
      "agentId": "validation_agent",
