{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/live-operation-state.schema.json",
  "title": "CEO G5 Live Operation State",
  "type": "object",
  "additionalProperties": true,
  "required": ["state", "live_real_enabled", "external_write_enabled", "mode"],
  "properties": {
    "state": {
      "type": "string",
      "enum": ["REQUESTED", "PREFLIGHT", "BLOCKED", "HOLD_OWNER", "MULTI_OWNER_PENDING", "APPROVED_FOR_SIMULATION", "ALLOW_LIVE_SIMULATED", "LIVE_ARMED_NOT_ENABLED", "EXECUTED_DRY_RUN", "ROLLBACK_VALIDATED", "FAILED", "CLOSED"]
    },
    "live_real_enabled": { "type": "boolean", "const": false },
    "external_write_enabled": { "type": "boolean", "const": false },
    "mode": { "type": "string", "enum": ["DRY_RUN", "CONTROLLED_WRITE", "OWNER_APPROVED_WRITE", "LIVE_CONTROLLED_SIMULATED"] }
  }
}
