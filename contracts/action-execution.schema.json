{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/action-execution.schema.json",
  "title": "CEO G4 Action Execution",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "execution_id",
    "action_id",
    "authorized",
    "dry_run",
    "status",
    "evidence_path"
  ],
  "properties": {
    "execution_id": { "type": "string", "minLength": 1 },
    "action_id": { "type": "string", "minLength": 1 },
    "authorized": { "type": "boolean" },
    "dry_run": { "type": "boolean", "const": true },
    "status": { "type": "string", "enum": ["EXECUTED_DRY_RUN", "BLOCKED", "FAILED"] },
    "evidence_path": { "type": "string", "minLength": 1 }
  }
}
