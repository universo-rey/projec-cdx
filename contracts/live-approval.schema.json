{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/live-approval.schema.json",
  "title": "CEO G5 Multi Owner Approval",
  "type": "object",
  "additionalProperties": true,
  "required": ["approval_id", "live_action_id", "approvals", "required_roles", "approval_status", "approved_at", "evidence_path"],
  "properties": {
    "approval_id": { "type": "string", "minLength": 1 },
    "live_action_id": { "type": "string", "minLength": 1 },
    "approvals": { "type": "array" },
    "required_roles": { "type": "array", "items": { "type": "string" } },
    "approval_status": { "type": "string", "enum": ["PENDING", "COMPLETE", "REJECTED"] },
    "approved_at": { "type": ["string", "null"] },
    "evidence_path": { "type": "string", "minLength": 1 }
  }
}
