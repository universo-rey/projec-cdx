{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/event-policy-decision.schema.json",
  "title": "CEO G2 Event Policy Decision",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event_id",
    "decision",
    "reason",
    "required_evidence",
    "policy_version",
    "timestamp"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "BLOCK",
        "HOLD_OWNER"
      ]
    },
    "reason": {
      "type": "string"
    },
    "required_evidence": {
      "type": "boolean"
    },
    "policy_version": {
      "type": "string",
      "const": "G2_POLICY_MINIMUM"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
