{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/live-guardrail.schema.json",
  "title": "CEO G5 Live Guardrail",
  "type": "object",
  "additionalProperties": true,
  "required": ["preflight_id", "live_action_id", "preflight_ok", "guardrails_passed", "guardrails_failed", "live_real_enabled"],
  "properties": {
    "preflight_id": { "type": "string", "minLength": 1 },
    "live_action_id": { "type": "string", "minLength": 1 },
    "preflight_ok": { "type": "boolean" },
    "guardrails_passed": { "type": "array" },
    "guardrails_failed": { "type": "array" },
    "live_real_enabled": { "type": "boolean", "const": false }
  }
}
