{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/event.schema.json",
  "title": "CEO G2 Persistent Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event_id",
    "event_type",
    "version",
    "timestamp",
    "producer",
    "correlation_id",
    "causation_id",
    "priority",
    "risk",
    "policy",
    "payload",
    "evidence",
    "state",
    "retry"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "state": {
      "$ref": "#/$defs/state"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "payload": {
      "type": "object"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "retry": {
      "$ref": "#/$defs/retry"
    }
  },
  "$defs": {
    "state": {
      "type": "string",
      "enum": [
        "CREATED",
        "PERSISTED",
        "VALIDATED",
        "POLICY_ALLOWED",
        "POLICY_BLOCKED",
        "HOLD_OWNER",
        "DISPATCHED",
        "PROCESSING",
        "COMPLETED",
        "FAILED_RETRYABLE",
        "FAILED_FINAL",
        "DLQ",
        "REPLAY_REQUESTED",
        "REPLAYED",
        "CLOSED"
      ]
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requires_owner_gate",
        "allows_write",
        "allows_live",
        "allows_delete",
        "dry_run_required"
      ],
      "properties": {
        "requires_owner_gate": {
          "type": "boolean"
        },
        "allows_write": {
          "type": "boolean"
        },
        "allows_live": {
          "type": "boolean"
        },
        "allows_delete": {
          "type": "boolean"
        },
        "dry_run_required": {
          "type": "boolean"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required",
        "path"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attempt",
        "max_attempts",
        "last_error",
        "next_action"
      ],
      "properties": {
        "attempt": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "last_error": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action": {
          "type": "string",
          "enum": [
            "retry",
            "dlq",
            "hold",
            "none"
          ]
        }
      }
    }
  }
}
