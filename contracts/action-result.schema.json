{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/action-result.schema.json",
  "title": "CEO G4 Action Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "result_id",
    "execution_id",
    "action_id",
    "status",
    "side_effects",
    "evidence_path"
  ],
  "properties": {
    "result_id": { "type": "string", "minLength": 1 },
    "execution_id": { "type": "string", "minLength": 1 },
    "action_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["DRY_RUN_RECORDED", "BLOCKED", "FAILED"] },
    "side_effects": { "type": "boolean", "const": false },
    "evidence_path": { "type": "string", "minLength": 1 }
  }
}
