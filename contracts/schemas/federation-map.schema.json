{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/federation-map.schema.json",
  "title": "Federation Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "federationId",
    "duplicatePolicy",
    "repos"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "federationId": {
      "type": "string",
      "minLength": 1
    },
    "duplicatePolicy": {
      "type": "string",
      "minLength": 1
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repoId",
          "remote",
          "canonicalPath",
          "role",
          "status",
          "alignmentStatus",
          "runtimePointer",
          "agents",
          "contracts",
          "environmentContract",
          "historicalPaths",
          "governance"
        ],
        "properties": {
          "repoId": {
            "type": "string",
            "minLength": 1
          },
          "remote": {
            "type": "string",
            "minLength": 1
          },
          "canonicalPath": {
            "type": "string",
            "minLength": 1
          },
          "physicalAlias": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "reference",
              "placeholder"
            ]
          },
          "alignmentStatus": {
            "type": "string",
            "enum": [
              "aligned",
              "partial",
              "pending"
            ]
          },
          "runtimePointer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "canonicalRuntimeRoot",
              "mode",
              "copyRuntime"
            ],
            "properties": {
              "canonicalRuntimeRoot": {
                "type": "string",
                "minLength": 1
              },
              "mode": {
                "type": "string",
                "enum": [
                  "owned-runtime",
                  "reference-only"
                ]
              },
              "copyRuntime": {
                "type": "boolean",
                "enum": [
                  false
                ]
              }
            }
          },
          "agents": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "contracts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "environmentContract": {
            "type": "string",
            "minLength": 1
          },
          "historicalPaths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "governance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ownerAgent",
              "authorityLevel",
              "surface",
              "allowedActions",
              "blockedActions",
              "requiredRecipe",
              "requiredTool",
              "evidence",
              "validator",
              "stopCondition"
            ],
            "properties": {
              "ownerAgent": {
                "type": "string",
                "minLength": 1
              },
              "authorityLevel": {
                "type": "string",
                "minLength": 1
              },
              "surface": {
                "type": "string",
                "minLength": 1
              },
              "allowedActions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "blockedActions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "requiredRecipe": {
                "type": "string",
                "minLength": 1
              },
              "requiredTool": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              },
              "validator": {
                "type": "string",
                "minLength": 1
              },
              "stopCondition": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
