{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/agent-decision.payload.schema.json",
  "title": "Agent Decision Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceEventId",
    "sourceTraceId",
    "sourceSpanId",
    "sourceParentSpanId",
    "sourceType",
    "chainId",
    "chainStatus",
    "execution",
    "agentDecisions",
    "result",
    "policy",
    "priorityRule",
    "conflict",
    "conflictReason",
    "conflictResolution",
    "finalState",
    "chainMemoryRef",
    "followUpEvents"
  ],
  "properties": {
    "sourceEventId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "sourceTraceId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "sourceSpanId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "sourceParentSpanId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "sourceType": {
      "type": "string",
      "minLength": 1
    },
    "chainId": {
      "type": "string",
      "minLength": 1
    },
    "chainStatus": {
      "type": "string",
      "enum": [
        "COMPLETE",
        "HELD",
        "CONFLICT",
        "NO_ROUTE"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "AGENT_DECISION_CREATED",
        "AGENT_DECISION_HELD",
        "AGENT_DECISION_NO_ROUTE",
        "AGENT_DECISION_CONFLICT"
      ]
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisionEngine",
        "runtimeRouter",
        "executionAdapter",
        "executionSurface",
        "executionPath",
        "adapterMode",
        "liveWrite",
        "secretAccess"
      ],
      "properties": {
        "decisionEngine": {
          "type": "string",
          "minLength": 1
        },
        "runtimeRouter": {
          "type": "string",
          "minLength": 1
        },
        "executionAdapter": {
          "type": "string",
          "minLength": 1
        },
        "executionSurface": {
          "type": "string",
          "enum": [
            "local",
            "codex",
            "cloud"
          ]
        },
        "executionPath": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "adapterMode": {
          "type": "string",
          "enum": [
            "local-only",
            "read-only-review",
            "placeholder"
          ]
        },
        "liveWrite": {
          "type": "boolean",
          "enum": [
            false
          ]
        },
        "secretAccess": {
          "type": "boolean",
          "enum": [
            false
          ]
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "action",
        "requiresApproval",
        "reason"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "action": {
          "type": "string"
        },
        "requiresApproval": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "priorityRule": {
      "type": "string",
      "minLength": 1
    },
    "conflict": {
      "type": "boolean"
    },
    "conflictReason": {
      "type": [
        "string",
        "null"
      ]
    },
    "conflictResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "strategy",
        "resolved",
        "reason",
        "priorityRule",
        "selectedAgentRole",
        "selectedDecisionType",
        "blockedFollowUps"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "NO_CONFLICT",
            "RESOLVED_FAIL_CLOSED",
            "POLICY_HELD",
            "NO_ROUTE"
          ]
        },
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "resolved": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "priorityRule": {
          "type": "string",
          "minLength": 1
        },
        "selectedAgentRole": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedDecisionType": {
          "type": [
            "string",
            "null"
          ]
        },
        "blockedFollowUps": {
          "type": "boolean"
        }
      }
    },
    "finalState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "result",
        "reason",
        "selectedAgentRole",
        "selectedDecisionType",
        "selectedPriority",
        "stopCondition"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "COMPLETE",
            "HOLD",
            "CONFLICT_HELD",
            "NO_ROUTE"
          ]
        },
        "result": {
          "type": "string",
          "enum": [
            "ALLOW",
            "HOLD"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "selectedAgentRole": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedDecisionType": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedPriority": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "stopCondition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "chainMemoryRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memoryKey",
        "memoryFile"
      ],
      "properties": {
        "memoryKey": {
          "type": "string",
          "minLength": 1
        },
        "memoryFile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "followUpEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "condition",
          "priority",
          "decisionType",
          "status",
          "reason",
          "emittedEventId"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "decisionType": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "emitted",
              "blocked",
              "skipped"
            ]
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "emittedEventId": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
          }
        }
      }
    },
    "agentDecisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "agentId",
          "agentRole",
          "sequence",
          "priority",
          "decisionType",
          "executionSurface",
          "traceId",
          "spanId",
          "parentSpanId",
          "timestamp",
          "result",
          "tool",
          "evidence",
          "validator",
          "stopCondition",
          "holdReason"
        ],
        "properties": {
          "agentId": {
            "type": "string",
            "minLength": 1
          },
          "agentRole": {
            "type": "string",
            "minLength": 1
          },
          "sequence": {
            "type": "integer",
            "minimum": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "decisionType": {
            "type": "string",
            "minLength": 1
          },
          "executionSurface": {
            "type": "string",
            "enum": [
              "local",
              "codex",
              "cloud"
            ]
          },
          "traceId": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
          },
          "spanId": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
          },
          "parentSpanId": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "result": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "validator": {
            "type": "string",
            "minLength": 1
          },
          "stopCondition": {
            "type": "string",
            "minLength": 1
          },
          "holdReason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
