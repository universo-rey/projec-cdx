{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/predictive-signal.payload.schema.json",
  "title": "Predictive Signal Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signal",
    "confidence",
    "basis"
  ],
  "properties": {
    "signal": {
      "type": "string",
      "enum": [
        "STABLE",
        "INCIDENT_LIKELY",
        "PERFORMANCE_DEGRADING",
        "NO_DATA"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "basis": {
      "type": "string",
      "minLength": 1
    }
  }
}
