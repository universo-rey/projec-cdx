{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/alert-raised.payload.schema.json",
  "title": "Alert Raised Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "level",
    "message"
  ],
  "properties": {
    "level": {
      "type": "string",
      "enum": [
        "INFO",
        "WARNING",
        "CRITICAL"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "sourceEventType": {
      "type": "string"
    }
  }
}
