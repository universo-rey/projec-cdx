{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/system-nervous-index.schema.json",
  "title": "CEO System Nervous Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceOfTruth",
    "generatedAt",
    "repoId",
    "canonicalRoot",
    "federationId",
    "sources",
    "paths",
    "agents",
    "routes",
    "vsiControlPlane",
    "agileAgentCanvas",
    "dependencies",
    "policy"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+$" },
    "sourceOfTruth": { "type": "string", "enum": ["SYSTEM_NERVOUS_INDEX"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repoId": { "type": "string", "minLength": 1 },
    "canonicalRoot": { "type": "string", "minLength": 1 },
    "federationId": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "count", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["READY", "MISSING", "DEGRADED"] }
        }
      }
    },
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pathType", "path", "canonicalPath", "status"],
        "properties": {
          "pathType": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "canonicalPath": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["READY", "ALIAS_REWRITTEN", "OBSERVED", "HELD"] }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agentId", "owner", "surface", "tool", "evidence", "validator", "stopCondition", "status"],
        "properties": {
          "agentId": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "tool": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "validator": { "type": "string", "minLength": 1 },
          "stopCondition": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["ACTIVE", "HELD"] }
        }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eventType", "chainId", "agents"],
        "properties": {
          "eventType": { "type": "string", "minLength": 1 },
          "chainId": { "type": "string", "minLength": 1 },
          "agents": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "vsiControlPlane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace", "tasks", "status"],
      "properties": {
        "workspace": { "type": "string", "minLength": 1 },
        "tasks": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["READY", "HELD"] }
      }
    },
    "agileAgentCanvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "workflows", "status"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "workflows": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "status": { "type": "string", "enum": ["READY", "DEGRADED", "HELD"] }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "type", "status"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["READY", "HELD"] }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["failClosed", "liveWrite", "secretAccess", "requiredForExecution"],
      "properties": {
        "failClosed": { "type": "boolean", "enum": [true] },
        "liveWrite": { "type": "boolean", "enum": [false] },
        "secretAccess": { "type": "boolean", "enum": [false] },
        "requiredForExecution": { "type": "boolean", "enum": [true] }
      }
    }
  }
}
