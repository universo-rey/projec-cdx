{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/vscode-drift.payload.schema.json",
  "title": "VS Code Insiders Drift Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "driftStatus"
  ],
  "properties": {
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "driftStatus": {
      "type": "string",
      "enum": [
        "OK",
        "DRIFT"
      ]
    },
    "addedExtensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "removedExtensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
