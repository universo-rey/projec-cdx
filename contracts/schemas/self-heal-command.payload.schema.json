{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/self-heal-command.payload.schema.json",
  "title": "Self Heal Command Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "targetTraceId",
    "command",
    "reason"
  ],
  "properties": {
    "targetTraceId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "command": {
      "type": "string",
      "enum": [
        "noop",
        "retry-local",
        "hold",
        "snapshot-local"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
