{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/trace-node.schema.json",
  "title": "Trace Node",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "traceId",
    "spanId",
    "type",
    "status",
    "durationMs"
  ],
  "properties": {
    "traceId": {
      "type": "string"
    },
    "spanId": {
      "type": "string"
    },
    "parentSpanId": {
      "type": [
        "string",
        "null"
      ]
    },
    "type": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "durationMs": {
      "type": "number",
      "minimum": 0
    }
  }
}
