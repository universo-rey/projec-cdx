{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/vsi-guard-result.payload.schema.json",
  "title": "CEO VSI Guard Result Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "guardId",
    "checkedAt",
    "status",
    "signals",
    "requiredContext",
    "recommendation",
    "sensitiveContentDetected",
    "liveWrite"
  ],
  "properties": {
    "guardId": { "type": "string", "minLength": 1 },
    "checkedAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["PASS", "WARN", "HELD"] },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "evidence"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["PASS", "WARN", "BLOCK", "OBSERVED"] },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requiredContext": { "type": "string", "minLength": 1 },
    "recommendation": { "type": "string", "minLength": 1 },
    "sensitiveContentDetected": { "type": "boolean", "enum": [false] },
    "liveWrite": { "type": "boolean", "enum": [false] }
  }
}
