{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/sns-unified-index.payload.schema.json",
  "title": "CEO SNS Unified Index Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snsId",
    "generatedAt",
    "sourceOfTruth",
    "sources",
    "rootIndexCount",
    "operativaIndexCount",
    "localNervousRoots",
    "status",
    "issues",
    "outputPath",
    "sensitiveContentDetected",
    "liveWrite"
  ],
  "properties": {
    "snsId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceOfTruth": { "type": "string", "enum": ["system-nervous-index"] },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "count", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["READY", "MISSING", "DEGRADED"] }
        }
      }
    },
    "rootIndexCount": { "type": "integer", "minimum": 0 },
    "operativaIndexCount": { "type": "integer", "minimum": 0 },
    "localNervousRoots": { "type": "integer", "minimum": 0 },
    "status": { "type": "string", "enum": ["READY", "DEGRADED", "HELD"] },
    "issues": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "outputPath": { "type": "string", "minLength": 1 },
    "sensitiveContentDetected": { "type": "boolean", "enum": [false] },
    "liveWrite": { "type": "boolean", "enum": [false] }
  }
}
