{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/environment-contract.schema.json",
  "title": "Environment Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractId",
    "surfaces",
    "requiredVariables",
    "forbiddenVariables",
    "consistencyRules"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "contractId": {
      "type": "string",
      "minLength": 1
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "local",
          "vsi",
          "codespaces"
        ]
      }
    },
    "requiredVariables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "required",
          "rule"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "rule": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "forbiddenVariables": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "consistencyRules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
