{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/event-envelope.schema.json",
  "title": "CEO Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "traceId",
    "spanId",
    "type",
    "domain",
    "timestamp",
    "status",
    "priority",
    "schemaVersion",
    "executionSurface",
    "payload",
    "metadata"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "spanId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "parentSpanId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "RUNTIME_DRIFT",
        "VSCODE_DRIFT",
        "ALERT_RAISED",
        "SELF_HEAL_COMMAND",
        "PREDICTIVE_SIGNAL",
        "OPTIMIZATION_COMMAND",
        "POLICY_DECISION",
        "AGENT_DECISION",
        "SANITIZATION_FINDING",
        "RUNTIME_DIAGNOSIS",
        "SANITIZE_REQUIRED",
        "FEDERATION_DRIFT",
        "SNS_UNIFIED_INDEX",
        "VSI_GUARD_RESULT",
        "CONTROL_PLANE_SYNC"
      ]
    },
    "domain": {
      "type": "string",
      "enum": [
        "runtime",
        "event-bus",
        "observability",
        "policy",
        "healing",
        "predictive",
        "optimization",
        "soc-visual",
        "ide",
        "agents",
        "governance",
        "diagnostic"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "processing",
        "done",
        "failed",
        "held",
        "rejected"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "executionSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaceId",
        "adapterId",
        "decisionEngine",
        "runtimeRouter",
        "executionAdapter",
        "executionPath",
        "mode",
        "liveWrite",
        "secretAccess"
      ],
      "properties": {
        "surfaceId": {
          "type": "string",
          "enum": [
            "local",
            "codex",
            "cloud"
          ]
        },
        "adapterId": {
          "type": "string",
          "enum": [
            "local",
            "codex",
            "cloud"
          ]
        },
        "decisionEngine": {
          "type": "string",
          "minLength": 1
        },
        "runtimeRouter": {
          "type": "string",
          "minLength": 1
        },
        "executionAdapter": {
          "type": "string",
          "minLength": 1
        },
        "executionPath": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "local-only",
            "read-only-review",
            "placeholder"
          ]
        },
        "liveWrite": {
          "type": "boolean",
          "enum": [
            false
          ]
        },
        "secretAccess": {
          "type": "boolean",
          "enum": [
            false
          ]
        }
      }
    },
    "payload": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
        "required": [
          "cabinaId",
          "executionAdapterId",
          "governance"
        ],
        "properties": {
          "cabinaId": {
            "type": "string",
            "minLength": 1
          },
          "executionAdapterId": {
            "type": "string",
            "minLength": 1
          },
          "workerId": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
        "governance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "agent",
            "skill",
            "recipe",
            "tool",
            "evidence",
            "validator",
            "stopCondition"
          ],
          "properties": {
            "agent": {
              "type": "string",
              "minLength": 1
            },
            "skill": {
              "type": "string",
              "minLength": 1
            },
            "recipe": {
              "type": "string",
              "minLength": 1
            },
            "tool": {
              "type": "string",
              "minLength": 1
            },
            "evidence": {
              "type": "string",
              "minLength": 1
            },
            "validator": {
              "type": "string",
              "minLength": 1
            },
            "stopCondition": {
              "type": "string",
              "minLength": 1
            },
            "authorityLevel": {
              "type": "string"
            }
          }
        }
      }
    },
    "policyDecision": {
      "type": "object"
    },
    "dispatchResult": {
      "type": "string"
    },
    "agentDecisionResult": {
      "type": "string"
    },
    "processedAt": {
      "type": "string",
      "format": "date-time"
    },
    "failedAt": {
      "type": "string",
      "format": "date-time"
    },
    "durationMs": {
      "type": "number",
      "minimum": 0
    },
    "error": {
      "type": "string"
    }
  }
}
