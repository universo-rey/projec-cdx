{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/runtime-diagnosis.payload.schema.json",
  "title": "Runtime Diagnosis Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagnosisId",
    "diagnosedAt",
    "scope",
    "status",
    "probableCause",
    "signals",
    "recommendation",
    "sensitiveContentDetected",
    "liveWrite"
  ],
  "properties": {
    "diagnosisId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "diagnosedAt": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "STABLE",
        "DEGRADED",
        "HELD"
      ]
    },
    "probableCause": {
      "type": "string",
      "minLength": 1
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "evidence"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL",
              "HELD"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    },
    "sensitiveContentDetected": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "liveWrite": {
      "type": "boolean",
      "enum": [
        false
      ]
    }
  }
}
