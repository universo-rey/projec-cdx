{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ceo://contracts/federation-drift.payload.schema.json",
  "title": "CEO Federation Drift Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "driftId",
    "checkedAt",
    "federationId",
    "repoId",
    "severity",
    "status",
    "issues",
    "canonicalPath",
    "physicalAlias",
    "duplicateDetected",
    "recommendation",
    "sensitiveContentDetected",
    "liveWrite"
  ],
  "properties": {
    "driftId": { "type": "string", "minLength": 1 },
    "checkedAt": { "type": "string", "format": "date-time" },
    "federationId": { "type": "string", "minLength": 1 },
    "repoId": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
    "status": { "type": "string", "enum": ["OK", "DRIFT", "HELD"] },
    "issues": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "canonicalPath": { "type": "string", "minLength": 1 },
    "physicalAlias": { "type": ["string", "null"] },
    "duplicateDetected": { "type": "boolean" },
    "recommendation": { "type": "string", "minLength": 1 },
    "sensitiveContentDetected": { "type": "boolean", "enum": [false] },
    "liveWrite": { "type": "boolean", "enum": [false] }
  }
}
