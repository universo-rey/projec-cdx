{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/event-bus-state.schema.json",
  "title": "CEO G2 Event Bus State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "root",
    "inbox",
    "processing",
    "completed",
    "failed",
    "dlq",
    "traces",
    "replay",
    "evidence",
    "state"
  ],
  "properties": {
    "root": {
      "type": "string"
    },
    "inbox": {
      "type": "integer",
      "minimum": 0
    },
    "processing": {
      "type": "integer",
      "minimum": 0
    },
    "completed": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "dlq": {
      "type": "integer",
      "minimum": 0
    },
    "traces": {
      "type": "integer",
      "minimum": 0
    },
    "replay": {
      "type": "integer",
      "minimum": 0
    },
    "evidence": {
      "type": "integer",
      "minimum": 0
    },
    "state": {
      "type": "string"
    }
  }
}
