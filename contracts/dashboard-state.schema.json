{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/dashboard-state.schema.json",
  "title": "CEO G3 Dashboard State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "generated_at",
    "health",
    "queues",
    "policy",
    "failures",
    "dlq",
    "replay",
    "anomalies",
    "alerts"
  ],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "health": { "type": "string", "enum": ["OK", "WARN", "CRITICAL"] },
    "queues": { "type": "object" },
    "policy": { "type": "object" },
    "failures": { "type": "object" },
    "dlq": { "type": "object" },
    "replay": { "type": "object" },
    "anomalies": { "type": "object" },
    "alerts": { "type": "object" }
  }
}
