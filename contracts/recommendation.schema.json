{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/recommendation.schema.json",
  "title": "CEO G3 Policy Feedback Recommendation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "recommendation_id",
    "created_at",
    "source",
    "type",
    "suggested_action",
    "risk",
    "requires_owner_gate",
    "status"
  ],
  "properties": {
    "recommendation_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "suggested_action": { "type": "string", "minLength": 1 },
    "risk": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "requires_owner_gate": { "type": "boolean" },
    "status": { "type": "string", "const": "SUGGESTED" }
  }
}
