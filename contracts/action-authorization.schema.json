{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/action-authorization.schema.json",
  "title": "CEO G4 Action Authorization",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "authorization_id",
    "action_id",
    "decision",
    "authorized",
    "owner_gate_required",
    "reason",
    "evidence_path"
  ],
  "properties": {
    "authorization_id": { "type": "string", "minLength": 1 },
    "action_id": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "enum": ["ALLOW", "BLOCK", "HOLD_OWNER"] },
    "authorized": { "type": "boolean" },
    "owner_gate_required": { "type": "boolean" },
    "reason": { "type": "string", "minLength": 1 },
    "evidence_path": { "type": "string", "minLength": 1 }
  }
}
