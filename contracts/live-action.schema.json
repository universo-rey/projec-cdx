{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/live-action.schema.json",
  "title": "CEO G5 Live Action Request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "live_action_id",
    "action_id",
    "event_id",
    "environment",
    "action_type",
    "requested_at",
    "requested_by",
    "source",
    "risk",
    "mode",
    "target",
    "policy",
    "rollback",
    "evidence",
    "approvals",
    "trace"
  ],
  "properties": {
    "live_action_id": { "type": "string", "minLength": 1 },
    "action_id": { "type": "string", "minLength": 1 },
    "event_id": { "type": "string", "minLength": 1 },
    "environment": { "type": "string", "minLength": 1 },
    "action_type": { "type": "string", "minLength": 1 },
    "requested_at": { "type": "string", "format": "date-time" },
    "requested_by": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "risk": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "mode": { "type": "string", "enum": ["DRY_RUN", "CONTROLLED_WRITE", "OWNER_APPROVED_WRITE", "LIVE_CONTROLLED_SIMULATED"] },
    "target": { "type": "string", "minLength": 1 },
    "policy": { "type": "object" },
    "rollback": { "type": "object" },
    "evidence": { "type": "object" },
    "approvals": { "type": "object" },
    "trace": { "type": "object" }
  }
}
