{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/event-trace.schema.json",
  "title": "CEO G2 Event Trace",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "trace_id",
    "event_id",
    "correlation_id",
    "nodes",
    "edges",
    "policy_decision",
    "evidence"
  ],
  "properties": {
    "trace_id": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array"
    },
    "edges": {
      "type": "array"
    },
    "policy_decision": {
      "type": "string"
    },
    "evidence": {
      "type": "array"
    }
  }
}
