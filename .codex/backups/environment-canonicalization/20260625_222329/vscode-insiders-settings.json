        "PowerShell 7 (CEO Safe)": {
            "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
            "args": [
                "-NoLogo",
                "-NoProfile"
            ],
            "icon": "terminal-powershell"
        }
    },
    "terminal.integrated.cwd": "C:\\",
    "terminal.integrated.env.windows": {
        "CODEX_PWSH_PATH": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
        "CODEX_PAC_PATH": "C:\\CEO\\tools\\pac\\microsoft.powerapps.cli.2.8.1\\tools\\pac.exe",
        "PATH": "${env:PATH};C:\\Program Files\\Docker\\Docker\\resources\\bin"
    },
    "workbench.colorTheme": "Default High Contrast",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:claude-sonnet-4.6",
