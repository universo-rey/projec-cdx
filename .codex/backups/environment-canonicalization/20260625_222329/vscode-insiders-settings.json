        "PowerShell 7": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
    },
    "powershell.powerShellDefaultVersion": "PowerShell 7",
    "dev.containers.dockerPath": "C:\\Program Files\\Docker\\Docker\\resources\\bin\\docker.exe",
    "editor.formatOnSave": false,
    "files.trimTrailingWhitespace": false,
    "files.exclude": {
        "**/.env": true,
        "**/.env.*": true,
        "**/*token*": true,
        "**/*secret*": true,
        "**/*cookie*": true,
        "**/node_modules": true,
        "**/.venv": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true
    },
    "search.exclude": {
        "**/.git": true,
        "**/.env": true,
        "**/.env.*": true,
        "**/*token*": true,
        "**/*secret*": true,
        "**/*cookie*": true,
        "**/node_modules": true,
        "**/.venv": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true
    },
    "files.watcherExclude": {
        "**/.git/**": true,
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true
