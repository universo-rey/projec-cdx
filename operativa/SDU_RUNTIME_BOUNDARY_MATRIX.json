{
  "version": "2026-06-22",
  "default_mode": "NO_EXTERNAL",
  "description": "Matriz de frontera operativa SDU — baseline v0.1.0",
  "surfaces": [
    {
      "surface": "local",
      "actions": ["read", "analyze", "test", "refactor", "metadata", "index"],
      "policy": "ALLOWED"
    },
    {
      "surface": "github",
      "actions": ["push", "pr", "write", "workflow_dispatch"],
      "policy": "BLOCKED_WITHOUT_GATE"
    },
    {
      "surface": "openai",
      "actions": ["api_call", "batch", "vector_store", "file_search"],
      "policy": "BLOCKED_WITHOUT_GATE"
    },
    {
      "surface": "microsoft",
      "actions": ["graph", "sharepoint_write", "teams_write"],
      "policy": "BLOCKED_WITHOUT_GATE"
    },
    {
      "surface": "sharepoint",
      "actions": ["read_full", "write", "list_mutation"],
      "policy": "BLOCKED_WITHOUT_GATE"
    },
    {
      "surface": "dataverse",
      "actions": ["read", "write", "table_mutation"],
      "policy": "BLOCKED_WITHOUT_GATE"
    },
    {
      "surface": "power_platform",
      "actions": ["flow_trigger", "flow_mutation", "connection_mutation"],
      "policy": "BLOCKED_WITHOUT_GATE"
    },
    {
      "surface": "codex_cloud",
      "actions": ["execute", "sync", "remote_mutation"],
      "policy": "BLOCKED_WITHOUT_GATE"
    }
  ],
  "rules": {
    "no_external_without_gate": true,
    "no_secret_exposure": true,
    "no_implicit_execution": true
  }
}
